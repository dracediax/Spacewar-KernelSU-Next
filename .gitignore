# Build output (boot.img, zip, rawfiles)
output/

# Boot images and zips (local artifacts)
*.img
*.zip

# Track release extras in assets/
!assets/LSPosed-*.zip
!assets/HMA-OSS_config.json
!assets/nothing_logo_white.png
!assets/dmverity-props-spoof-v1.1.zip
